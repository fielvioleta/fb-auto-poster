# ---- Core (required) ----
OPENAI_API_KEY=
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=
PORT=3000

# ---- Optional ----
# Model used for caption generation
OPENAI_MODEL=gpt-4o-mini

# Graph API version
FACEBOOK_GRAPH_VERSION=v21.0

# Scheduler
# Cron expression (defaults to daily at 11:00). Timezone is fixed to Asia/Manila.
CRON_SCHEDULE=0 11 * * *
SCHEDULER_ENABLED=true
TIMEZONE=Asia/Manila

# When true, the scheduler generates AND publishes automatically.
# When false, it only generates and stores a draft (no auto-publish).
AUTO_PUBLISH=true

# Logging
LOG_LEVEL=info

# Caption language: english | taglish | tagalog
POST_LANGUAGE=taglish

# ---- Bonus features ----
# Weather-aware captions (https://open-meteo.com - no API key needed).
WEATHER_ENABLED=true
# Latitude/longitude of the restaurant (defaults to Manila).
RESTAURANT_LAT=14.5995
RESTAURANT_LON=120.9842

# Holiday-aware posts (https://date.nager.at - no API key needed).
HOLIDAY_ENABLED=true
HOLIDAY_COUNTRY_CODE=PH

# AI image prompt generation (text prompt only, no image is uploaded by default).
IMAGE_PROMPT_ENABLED=true

# Reuse photos from your Facebook Page (Vision tags once, AI picks best match per post).
PAGE_PHOTOS_ENABLED=true
PAGE_PHOTOS_MAX=50
